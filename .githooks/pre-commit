#!/bin/sh
# Block commits that change a notebook without a matching runs/ record.
set -e
staged=$(git diff --cached --name-only --diff-filter=ACM -- 'notebooks/*.py')
[ -z "$staged" ] && exit 0
if ! python3 scripts/check_runs.py $staged; then
    echo "" >&2
    echo "pre-commit: record a run first, then stage it: make record NB=<notebook>" >&2
    exit 1
fi
